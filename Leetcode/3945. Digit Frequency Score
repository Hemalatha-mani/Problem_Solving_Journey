class Solution {
    public int digitFrequencyScore(int n) {
        
        HashMap<Integer,Integer> map=new HashMap<>();
        while(n!=0){
            int d=n%10;
            map.put(d,map.getOrDefault(d,0)+1);
            n=n/10;
        }
        int sum=0;
        for(int key:map.keySet()){
            int ans=key*map.get(key);
            sum=sum+ans;

        }
        return sum;

        
    }
}
