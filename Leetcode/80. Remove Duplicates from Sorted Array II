80. Remove Duplicates from Sorted Array II

class Solution {
    public int removeDuplicates(int[] nums) {
        int k=0;
        HashMap<Integer,Integer> map=new HashMap<>();
        for(int i=0;i<nums.length;i++){
            int n=nums[i];
            
            map.put(n,map.getOrDefault(n,0)+1);
            if(map.get(n)>2){
                //k++;
            	continue;
            }
            else {
                nums[k]=nums[i];
            	k++;}
            
        }
        return k;
        
    }
}
