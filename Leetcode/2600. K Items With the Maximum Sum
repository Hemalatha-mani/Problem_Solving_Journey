2600. K Items With the Maximum Sum

class Solution {
    public int kItemsWithMaximumSum(int numOnes, int numZeros, int numNegOnes, int k) {

        int count=0;
        int sum=0;
        while(k!=0){
            if(numOnes!=0 & k!=0){
                sum++;
                numOnes--;
                k--;
            
            }
            if(numOnes==0 & k!=0 & numZeros!=0){
                //sum++;
                numZeros--;
                k--;
            }
            if(numOnes==0 & k!=0 & numZeros==0 & numNegOnes!=0){
                sum--;
                numNegOnes--;
                k--;
            }
        }
        
        //return Math.min(numOnes,k);
        return sum;
    }
}
