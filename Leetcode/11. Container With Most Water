11. Container With Most Water

import java.util.*;
class Solution {
    public int maxArea(int[] height) {
        int max=Integer.MIN_VALUE;
        int l=0;
        int r=height.length-1;
        
        while(l<=r){
            int hei=Math.min(height[l],height[r]);
            int wid=r-l;
            int area=hei*wid;
            max=Math.max(max,area);
            if(height[r]>height[l]){
                l++;
            }
            else{
                r--;
            }
        
            
        }
        return max;
        
    }
}
