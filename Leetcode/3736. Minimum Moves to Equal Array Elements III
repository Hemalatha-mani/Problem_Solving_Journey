3736. Minimum Moves to Equal Array Elements III

class Solution {
    public int minMoves(int[] nums) {
        int max=Integer.MIN_VALUE;
        for(int i=0;i<nums.length;i++){
            if(nums[i]>max){
                max=nums[i];
            }
        }
        int moves=0;
        for(int i=0;i<nums.length;i++){
            if(nums[i]!=max){
                moves=moves+max-nums[i];
            }

        }
        return moves;
        
    }
}
