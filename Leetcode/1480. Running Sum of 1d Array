1480. Running Sum of 1d Array

class Solution {
    public int[] runningSum(int[] nums) {
        int ans[]=new int[nums.length];
        
        for(int i=0;i<nums.length;i++){
            int sum=0;
            for(int j=i;j>=0;j--){
                sum=sum+(nums[j]);
            }
            ans[i]=sum;
        }
        return ans;
        
    }
}
