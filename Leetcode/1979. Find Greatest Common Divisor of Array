1979. Find Greatest Common Divisor of Array

class Solution {
    public int findGCD(int[] nums) {
        int min=Integer.MAX_VALUE;
        int max=Integer.MIN_VALUE;
        for(int i=0;i<nums.length;i++){
            if(nums[i]<min){
                min=nums[i];
            }
            if(nums[i]>max){
                max=nums[i];
            }
        }
        
        int gcd=Integer.MIN_VALUE;
        for(int i=1;i<=max;i++){
            if(min%i==0 & max%i==0){
                gcd=Math.max(gcd,i);

            }
        }
        return gcd;
        
        
    }
}
