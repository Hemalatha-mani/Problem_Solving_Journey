9. Palindrome Number

class Solution {
    public boolean isPalindrome(int x) {
        int temp=x;
        int reverse=0;
        int rem=0;
        while(x>0)
        {
            rem=x%10;
            reverse=(reverse*10)+rem;
            x=x/10;

        }
        if(temp==reverse){
            return true;
        }
    return false;
    }
}
