3289. The Two Sneaky Numbers of Digitville

import java.util.*;
class Solution {
    public int[] getSneakyNumbers(int[] nums) {
        HashMap<Integer,Integer> map=new HashMap<>();
        for(int x:nums){
            map.put(x,map.getOrDefault(x,0)+1);
        }
        int ans[]=new int[2];
        int ind=0;
        for(int k:map.keySet()){
            if(map.get(k)==2){
                ans[ind++]=k;
            }
        }
        
        return ans;
    }
}
